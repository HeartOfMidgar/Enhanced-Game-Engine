{
  "name": "game-engine-enhanced",
  "version": "0.2.0",
  "description": "A modern, modular TypeScript game engine with Three.js rendering, bitecs ECS, cannon-es physics, ws networking, and Solana-aware blockchain plumbing.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "import": "./dist/physics/index.js"
    },
    "./input": {
      "types": "./dist/input/index.d.ts",
      "import": "./dist/input/index.js"
    },
    "./audio": {
      "types": "./dist/audio/index.d.ts",
      "import": "./dist/audio/index.js"
    },
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "import": "./dist/assets/index.js"
    },
    "./net": {
      "types": "./dist/net/index.d.ts",
      "import": "./dist/net/index.js"
    },
    "./chain": {
      "types": "./dist/chain/index.d.ts",
      "import": "./dist/chain/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:lib": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "docs": "typedoc"
  },
  "keywords": [
    "game-engine",
    "typescript",
    "three.js",
    "ecs",
    "bitecs",
    "cannon-es",
    "websocket",
    "solana",
    "web3"
  ],
  "author": "HeartOfMidgar (Saltaire Protocol)",
  "license": "MIT",
  "homepage": "https://github.com/HeartOfMidgar/Enhanced-Game-Engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/HeartOfMidgar/Enhanced-Game-Engine.git"
  },
  "bugs": {
    "url": "https://github.com/HeartOfMidgar/Enhanced-Game-Engine/issues"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bitecs": "^0.3.40",
    "bs58": "^6.0.0",
    "cannon-es": "^0.20.0",
    "express": "^4.21.2",
    "three": "^0.182.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.0.5",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@quarryprotocol/quarry-sdk": "^5.3.0",
    "@saberhq/solana-contrib": "^1.15.0",
    "@saberhq/token-utils": "^1.15.0",
    "ioredis": "^5.9.0"
  },
  "peerDependenciesMeta": {
    "@quarryprotocol/quarry-sdk": {
      "optional": true
    },
    "@saberhq/solana-contrib": {
      "optional": true
    },
    "@saberhq/token-utils": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/three": "^0.182.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.27.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.4"
  }
}
