# Server
PORT=3000
NODE_ENV=development

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_HELIUS_API_KEY=

# Token gate (the SPL mint your gate cares about)
TOKEN_GATE_MINT=
TOKEN_GATE_DECIMALS=9
TOKEN_GATE_MIN_BALANCE=0

# Reward sink (only set if you operate a reward server)
# Either a JSON array (Phantom export) or a base58 string. NEVER commit this.
REWARD_WALLET_PRIVATE_KEY=
REWARD_TOKEN_MINT=
REWARD_TOKEN_DECIMALS=9

# Optional: Redis-backed storage adapter
REDIS_URL=

# Optional: Quarry staking add-on (only if @quarryprotocol/quarry-sdk is installed)
QUARRY_REWARDER_ADDRESS=
QUARRY_STAKE_MINT=
QUARRY_STAKE_DECIMALS=9
QUARRY_IOU_MINT=
QUARRY_REDEEMER_WALLET=
